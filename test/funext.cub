-- funext test suite — one statement per line
-- Run with:  cubical test_funext.cub
--
-- Parser rules learned from reading Parser.hs:
--   • {x} body        = PLam, only valid as a TOP-LEVEL expression (twG), not an atom
--   • @ r             = PApp, r must be an atom (awG): a var, literal, or (parens)
--   • not_ i          = interval negation, ONLY inside [...] brackets
--   • {_ } x          = cannot appear as an argument; wrap in parens if needed
--   • Every statement must be a single physical line

-- ──────────────────────────────────────────────────────────────────────────────
-- §1  Canonical funext
--     Proof: ⟨i⟩ λ x. h x @ i
--     h x : Path B (f x) (g x), so (h x @ i) : B
--     At i=0: λx. f x   ≡ f   (eta)
--     At i=1: λx. g x   ≡ g   (eta)
-- ──────────────────────────────────────────────────────────────────────────────
check funext_check : PI (A : U0) . PI (B : U0) . PI (f : PI (_ : A) . B) . PI (g : PI (_ : A) . B) . PI (h : PI (x : A) . Path B (f x) (g x)) . Path (PI (_ : A) . B) f g = lambda_ A . lambda_ B . lambda_ f . lambda_ g . lambda_ h . {i} lambda_ x . h x @ i

-- ──────────────────────────────────────────────────────────────────────────────
-- §2  id ≡ id
--     Pointwise proof of (x ≡ x) is ⟨i⟩ x, but that PLam cannot appear as an
--     atom argument to @.  Instead we use the eta-refl shortcut:
--       {i} λ x. x    checks against  Path (A→A) id id
--     because at i=0 it gives λx.x = id, and at i=1 likewise.
-- ──────────────────────────────────────────────────────────────────────────────
check funext_id_id : PI (A : U0) . Path (PI (_ : A) . A) (lambda_ x . x) (lambda_ x . x) = lambda_ A . {i} lambda_ x . x

-- ──────────────────────────────────────────────────────────────────────────────
-- §3  Eta-expanded endpoints:  λx.fx ≡ f  held by eta-equality in the checker
-- ──────────────────────────────────────────────────────────────────────────────
check funext_eta_endpoints : PI (A : U0) . PI (B : U0) . PI (f : PI (_ : A) . B) . PI (g : PI (_ : A) . B) . PI (h : PI (x : A) . Path B (f x) (g x)) . Path (PI (_ : A) . B) (lambda_ x . f x) (lambda_ x . g x) = lambda_ A . lambda_ B . lambda_ f . lambda_ g . lambda_ h . {i} lambda_ x . h x @ i

-- ──────────────────────────────────────────────────────────────────────────────
-- §4  Constant function:  ⟨i⟩ λx. b  checks against Path (A→B) (λx.b) (λx.b)
--     Both endpoints reduce to λx.b definitionally.
-- ──────────────────────────────────────────────────────────────────────────────
check funext_const : PI (A : U0) . PI (B : U0) . PI (b : B) . Path (PI (_ : A) . B) (lambda_ x . b) (lambda_ x . b) = lambda_ A . lambda_ B . lambda_ b . {i} lambda_ x . b

-- ──────────────────────────────────────────────────────────────────────────────
-- §5  Reflexivity of function paths
--     ⟨i⟩ f  (constant path) has type Path (A→B) f f.
--     Written as ⟨i⟩ λx. f x so the checker sees a lambda it can evaluate.
-- ──────────────────────────────────────────────────────────────────────────────
check funext_refl : PI (A : U0) . PI (B : U0) . PI (f : PI (_ : A) . B) . Path (PI (_ : A) . B) f f = lambda_ A . lambda_ B . lambda_ f . {i} lambda_ x . f x

-- ──────────────────────────────────────────────────────────────────────────────
-- §6  Higher-order funext  (A → B → C)
-- ──────────────────────────────────────────────────────────────────────────────
check funext2 : PI (A : U0) . PI (B : U0) . PI (C : U0) . PI (f : PI (_ : A) . PI (_ : B) . C) . PI (g : PI (_ : A) . PI (_ : B) . C) . PI (h : PI (x : A) . PI (y : B) . Path C (f x y) (g x y)) . Path (PI (_ : A) . PI (_ : B) . C) f g = lambda_ A . lambda_ B . lambda_ C . lambda_ f . lambda_ g . lambda_ h . {i} lambda_ x . lambda_ y . h x y @ i

-- ──────────────────────────────────────────────────────────────────────────────
-- §7  Transitivity via hcomp
--     hcomp B [1] (⟨j⟩ h2 x @ j) (h1 x @ 1)
--     phi=1 so hcomp reduces to tube@1 = h2 x @ 1 = g→k endpoint
--     giving a path from f to k pointwise, hence Path (A→B) f k.
-- ──────────────────────────────────────────────────────────────────────────────
check funext_trans : PI (A : U0) . PI (B : U0) . PI (f : PI (_ : A) . B) . PI (g : PI (_ : A) . B) . PI (k : PI (_ : A) . B) . PI (h1 : PI (x : A) . Path B (f x) (g x)) . PI (h2 : PI (x : A) . Path B (g x) (k x)) . Path (PI (_ : A) . B) f k = lambda_ A . lambda_ B . lambda_ f . lambda_ g . lambda_ k . lambda_ h1 . lambda_ h2 . {i} lambda_ x . hcomp B [1] ({j} h2 x @ j) (h1 x @ 1)

-- ──────────────────────────────────────────────────────────────────────────────
-- §8  happly — extract pointwise paths
--     p : Path (A→B) f g
--     happly p x = ⟨i⟩ (p @ i) x
--     p @ i  has type A→B (PApp return type fix), applied to x gives B.
--     At i=0: (p@0) x = f x.   At i=1: (p@1) x = g x.
-- ──────────────────────────────────────────────────────────────────────────────
check happly : PI (A : U0) . PI (B : U0) . PI (f : PI (_ : A) . B) . PI (g : PI (_ : A) . B) . PI (p : Path (PI (_ : A) . B) f g) . PI (x : A) . Path B (f x) (g x) = lambda_ A . lambda_ B . lambda_ f . lambda_ g . lambda_ p . lambda_ x . {i} (p @ i) x

-- ──────────────────────────────────────────────────────────────────────────────
-- §9  funext then happly round-trip
--     happly (funext h) x
--       = ⟨i⟩ ((⟨j⟩ λy. h y @ j) @ i) x
--       = ⟨i⟩ (λy. h y @ i) x
--       = ⟨i⟩ h x @ i
--       = h x  (definitionally)
--     So we can give a refl proof of  Path (h x = h x).
-- ──────────────────────────────────────────────────────────────────────────────
check happly_funext_rt : PI (A : U0) . PI (B : U0) . PI (f : PI (_ : A) . B) . PI (g : PI (_ : A) . B) . PI (h : PI (x : A) . Path B (f x) (g x)) . PI (x : A) . Path (Path B (f x) (g x)) (h x) (h x) = lambda_ A . lambda_ B . lambda_ f . lambda_ g . lambda_ h . lambda_ x . {i} h x @ i

-- ──────────────────────────────────────────────────────────────────────────────
-- §10  funext then happly then funext again
--     Shows the full equivalence: we can go funext → happly → funext
--     and get the same path (definitionally equal to the original).
--     Proof: just apply funext again with the round-tripped pointwise paths.
-- ──────────────────────────────────────────────────────────────────────────────
check funext_happly_funext : PI (A : U0) . PI (B : U0) . PI (f : PI (_ : A) . B) . PI (g : PI (_ : A) . B) . PI (h : PI (x : A) . Path B (f x) (g x)) . Path (PI (_ : A) . B) f g = lambda_ A . lambda_ B . lambda_ f . lambda_ g . lambda_ h . {i} lambda_ x . h x @ i